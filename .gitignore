# Maven build output
target/

# Root src/ was removed during modularisation (M1); only empty OS-locked dirs may remain.
/src/

# IDE files
.idea/
*.iml
*.iws
*.ipr
.vscode/

# Claude Code internal state
.claude/

# OS artefacts
.DS_Store
Thumbs.db

# Playwright browser cache (downloaded separately with mvn test-compile -Dplaywright.install.skip=false)
playwright/

# Node.js runtime downloaded by frontend-maven-plugin (mvn verify -Dblotter.build.skip=false)
.node/

# Webapp dependencies (installed by frontend-maven-plugin or npm install)
b-bot-sandbox/src/test/webapp/node_modules/
b-bot-sandbox/src/test/webapp-config/node_modules/
b-bot-sandbox/src/test/webapp-deployment/node_modules/

# PT-Blotter Vite build output — assets/index.js and assets/index.css are git-tracked
# (committed as pre-built fallback so tests run without a Node build).
# The directory-level gitignore prevents accidentally committing chunked/hashed outputs.
b-bot-sandbox/src/test/resources/wiremock/__files/blotter/assets/

# Test evidence generated at runtime — not source-controlled
test-evidence/
